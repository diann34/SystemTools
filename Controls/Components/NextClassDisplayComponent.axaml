<ci:ComponentBase
    x:Class="SystemTools.Controls.Components.NextClassDisplayComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SystemTools.Controls.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:SystemTools.Models.ComponentSettings"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:TypeArguments="settings:NextClassDisplaySettings"
    Loaded="NextClassDisplayComponent_OnLoaded"
    Unloaded="NextClassDisplayComponent_OnUnloaded"
    mc:Ignorable="d">
    <Grid
        DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:NextClassDisplayComponent}}">
        <TextBlock
                   VerticalAlignment="Center"
                   Text="{Binding EmptyStateText, Mode=OneWay}"
                   FontSize="{DynamicResource MainWindowEmphasizedFontSize}"
                   FontWeight="Bold"
                   IsVisible="{Binding ShowEmptyState, Mode=OneWay}" />

        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    IsVisible="{Binding HasNextClass, Mode=OneWay}">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding PrefixText, Mode=OneWay}"
                       Classes="l-secondary"
                       IsVisible="{Binding ShowPrefixText, Mode=OneWay}" />

            <TextBlock VerticalAlignment="Center"
                       Text="{Binding SubjectName, Mode=OneWay}"
                       FontSize="{DynamicResource MainWindowEmphasizedFontSize}"
                       FontWeight="Bold" />

            <TextBlock VerticalAlignment="Center"
                       Text="{Binding TimeRangeText, Mode=OneWay}"
                       Classes="l-secondary"
                       IsVisible="{Binding ShouldShowTimeRange, Mode=OneWay}" />

            <TextBlock VerticalAlignment="Center"
                       Text="{Binding TeacherName, Mode=OneWay}"
                       Classes="l-secondary"
                       IsVisible="{Binding ShouldShowTeacherName, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</ci:ComponentBase>
